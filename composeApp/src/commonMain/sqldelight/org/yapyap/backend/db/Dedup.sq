insertDedup:
INSERT INTO dedup (
    packet_id,
    source_device_id,
    received_at
) VALUES (?, ?, ?);

selectDedupBySourceAndPacketId:
SELECT packet_id
FROM dedup
WHERE source_device_id = ?
  AND packet_id = ?
LIMIT 1;

updateNackReason:
UPDATE dedup
SET
    nack_reason = ?
WHERE source_device_id = ? AND packet_id = ?;

getNackReason:
SELECT nack_reason
FROM dedup
WHERE source_device_id = ? AND packet_id = ?;

deleteDedupReceivedBefore:
DELETE FROM dedup
WHERE received_at < ?;
